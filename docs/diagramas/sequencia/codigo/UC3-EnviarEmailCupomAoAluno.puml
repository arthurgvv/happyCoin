@startuml UC3-EnviarEmailCupomAoAluno

title UC3 - Enviar Email de Cupom ao Aluno\n(Notificação pós-resgate via RabbitMQ)

<style>
sequenceDiagram {
  messageAlign center
  responseMessageBelowArrow true
}
participant {
  padding 20
}
</style>

queue    "RabbitMQ\n(purchase.queue)"                as MQ
control  "<<control>>\nPurchaseEventConsumer"         as Consumer
database "<<entity>>\nProductPurchaseRepository"      as PurchaseRepo
control  "<<control>>\nEmailService"                  as EmailService
boundary "<<boundary>>\nJavaMailSender\n[SendGrid SMTP]" as SendGrid
actor    "<<actor>>\nAluno"                             as Student

MQ -> Consumer : onPurchase(PurchaseNotification)
activate Consumer

Consumer -> PurchaseRepo : findById(notification.purchaseId)
activate PurchaseRepo
PurchaseRepo --> Consumer : ProductPurchase
deactivate PurchaseRepo

Consumer -> EmailService : sendCouponEmailToStudent(\n  to          = notification.studentEmail,\n  nome        = notification.studentName,\n  produto     = notification.productName,\n  cupomId     = notification.purchaseId,\n  moedas      = notification.custoMoedas,\n  dataResgate = purchase.criadoEm)
activate EmailService

EmailService -> EmailService : monta HTML do email

EmailService -> SendGrid : mailSender.send(MimeMessage)\n[subject: "Seu cupom de resgate - HappyCoin"]
activate SendGrid
SendGrid --> EmailService : 250 OK
deactivate SendGrid

EmailService --> Consumer : (void)
deactivate EmailService

Consumer --> MQ : confirmação
deactivate Consumer

MQ --> Student : email entregue

@enduml
