@startuml

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequenceParticipantBorderThickness 1.5

actor "Usuario" as U
participant "Sistema de\nMoeda Estudantil" as SME
database "Banco de\nDados" as BD
participant "Servico de\nEmail (SendGrid)" as SE

== 1. Solicita recuperacao ==

U -> SME: 1.1 solicitarRecuperacaoSenha(email)

activate SME

SME -> BD: 1.2 buscarUsuarioPorEmail(email)

activate BD

BD --> SME: 1.3 dadosUsuario(id, email, status)

deactivate BD

alt E-mail cadastrado e usuario ativo

    SME -> SME: 1.4 gerarTokenRecuperacao()
    SME -> BD: 1.5 salvarTokenRecuperacao(usuarioID, token, validade)

    activate BD

    BD --> SME: 1.6 tokenSalvo

    deactivate BD

    SME ->> SE: 1.7 enviarEmailRecuperacao(email, linkRecuperacao)

    activate SE

    SE ->> U: 1.8 emailRecuperacaoSenha(linkRecuperacao)

    deactivate SE

    SME --> U: 1.9 informarEnvio("Verifique seu e-mail para redefinir a senha.")

else E-mail nao encontrado ou usuario inativo

    SME --> U: 1.10 informarEnvio("Se o e-mail estiver cadastrado, voce recebera as instrucoes.")

end

deactivate SME

== 2. Redefine senha ==

U -> SME: 2.1 redefinirSenha(token, novaSenha)

activate SME

SME -> BD: 2.2 validarTokenRecuperacao(token)

activate BD

BD --> SME: 2.3 resultadoToken(usuarioID, validade, usado)

deactivate BD

alt Token valido

    SME -> BD: 2.4 atualizarSenha(usuarioID, novaSenhaHash)

    activate BD

    BD --> SME: 2.5 senhaAtualizada

    deactivate BD

    SME -> BD: 2.6 invalidarToken(token)
    SME --> U: 2.7 senhaRedefinida("Senha alterada com sucesso.")

else Token invalido ou expirado

    SME --> U: 2.8 erroRecuperacao("Link invalido ou expirado.")

end

deactivate SME

@enduml
